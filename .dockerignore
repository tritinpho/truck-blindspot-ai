# Build context is the repo root for both images (deploy/docker-compose.yml). Keep it lean and
# never bake in local state.
.git
**/node_modules
**/dist
**/__pycache__
**/*.pyc
.pytest_cache
logs
*.log
**/.DS_Store
# never bake local secrets into an image layer (mirrors .gitignore; the context is the repo root)
**/.env
**/.env.*
**/*.pem
**/*.key
**/passwordfile
**/aclfile
